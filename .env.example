# Django
SECRET_KEY=change-me
ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
# DATABASE_URL=postgres://user:pass@host:5432/campscrow

# Settings module: manage.py defaults to campus.settings.development,
# wsgi/asgi to campus.settings.production. Override if needed:
# DJANGO_SETTINGS_MODULE=campus.settings.production

# WhatsApp Cloud API (production verification codes).
# Create a Meta app -> WhatsApp -> get a permanent access token and the
# sender's phone number ID, and approve an "authentication" template whose
# body takes the code as its single parameter (with a copy-code button).
WHATSAPP_BACKEND=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE=campscrow_verify
